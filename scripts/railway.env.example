# Copy to scripts/railway.env (gitignored) and fill in before running railway-deploy-all.sh
# Public URLs — use your Railway-generated domains (HTTPS, no trailing slash).
BACKEND_PUBLIC_URL=https://YOUR-BACKEND-SERVICE.up.railway.app
FRONTEND_PUBLIC_URL=https://YOUR-FRONTEND-SERVICE.up.railway.app

# Service names exactly as in Railway dashboard (defaults below match common naming).
BACKEND_SERVICE=api
FRONTEND_SERVICE=frontend

# Backend secrets (optional — set in Railway dashboard instead if you prefer)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# USE_MAINNET=true
# OPENAI_API_KEY=
# STRATEGY_CHAT_SECRET=
# TRADE_API_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Revolut X (set REVOLUT_X_PRIVATE_KEY_BASE64 = base64-encoded private.pem)
# REVOLUT_LIVE_ENABLED=true
# REVOLUT_X_API_KEY=
# REVOLUT_X_PRIVATE_KEY_BASE64=
# REVOLUT_X_BASE_URL=https://revx.revolut.com/api/1.0
# REVOLUT_X_SYMBOL=BTC-USD
# REVOLUT_X_MARKET_BASE_SIZE=0.00001
